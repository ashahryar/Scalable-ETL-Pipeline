{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3FullAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::yt-data-pipeline-bronze-layer/*",
                "arn:aws:s3:::yt-data-pipeline-bronze-layer",
                "arn:aws:s3:::yt-data-pipeline-silver-layer/*",
                "arn:aws:s3:::yt-data-pipeline-silver-layer",
                "arn:aws:s3:::yt-data-pipeline-gold-layer/*",
                "arn:aws:s3:::yt-data-pipeline-gold-layer",
                "arn:aws:s3:::yt-data-pipeline-scripts-layer/*",
                "arn:aws:s3:::yt-data-pipeline-scripts-layer"
            ]
        }
    ]
}